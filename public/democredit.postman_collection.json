{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-g7h8-i9j0-democredit-prod",
    "name": "demoCredit API (Render)",
    "description": "API for Wallet Management System - Lendsqr MVP",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"email\": \"john@example.com\",\n    \"phone\": \"08012345678\",\n    \"password\": \"Password123!\",\n    \"bvn\": \"22222222222\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"Password123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/logout"
            }
          }
        }
      ]
    },
    {
      "name": "Wallet",
      "item": [
        {
          "name": "Get Wallet Info",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/wallet"
            }
          }
        },
        {
          "name": "Fund Wallet",
          "request": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"amount\": 5000,\n    \"email\": \"john@example.com\",\n    \"reference\": \"FUND-{{$randomInt}}\",\n    \"category\": \"funding\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/wallet/fund"
            }
          }
        },
        {
          "name": "Transfer Funds",
          "request": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"receiver_user_id\": 2,\n    \"receiver_name\": \"Jane Smith\",\n    \"sender_name\": \"John Doe\",\n    \"amount\": 1000,\n    \"reference\": \"TRANS-{{$randomInt}}\",\n    \"category\": \"transfer\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/wallet/transfer"
            }
          }
        },
        {
          "name": "Withdraw Funds",
          "request": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"amount\": 2000,\n    \"reference\": \"WITH-{{$randomInt}}\",\n    \"counterparty_id\": \"1234567890\",\n    \"destination_bank_code\": \"058\",\n    \"counterparty_name\": \"John Doe Savings\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/wallet/withdraw"
            }
          }
        }
      ]
    },
    {
      "name": "User & Ledger",
      "item": [
        {
          "name": "Validate Receiver",
          "request": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"phone\": \"09087654321\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/user/validate-receiver"
            }
          }
        },
        {
          "name": "Get User Ledger",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/ledger/get-user-ledger"
            }
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Automatically injects the required client header into every request",
          "pm.request.headers.add({key: 'x-client-type', value: 'democredit-webapp' });"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://shalomhope-lendsqr-be-test.onrender.com/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ]
}