{
  "openapi": "3.0.0",
  "info": {
    "title": "demoCredit API",
    "description": "API documentation for the demoCredit Wallet Service MVP",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://shalomhope-lendsqr-be-test.onrender.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/api/auth/signup": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "User signup",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User created successfully",
            "headers": {
              "Set-Cookie": {
                "schema": {
                  "type": "string",
                  "example": "token=abc123xyz; HttpOnly; Path=/; Max-Age=86400"
                }
              }
            }
          },
          "400": {
            "description": "Validation failed"
          },
          "403": {
            "description": "Forbidden - User is blacklisted on Lendsqr Karma"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "User login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "headers": {
              "Set-Cookie": {
                "schema": {
                  "type": "string",
                  "example": "token=abc123xyz; HttpOnly; Path=/; Max-Age=86400"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "User logout",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Logged out successfully"
          }
        }
      }
    },
    "/api/user/validate-receiver": {
      "post": {
        "tags": [
          "User"
        ],
        "summary": "Validate receiver phone number",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ValidateReceiverInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Receiver valid",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "number"
                    },
                    "first_name": {
                      "type": "string"
                    },
                    "last_name": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/ledger/get-user-ledger": {
      "get": {
        "tags": [
          "Ledger"
        ],
        "summary": "Get user transaction history",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "User ledger retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/wallet": {
      "get": {
        "tags": [
          "Wallet"
        ],
        "summary": "Get user wallet balance",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Wallet data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "balance": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/wallet/fund": {
      "post": {
        "tags": [
          "Wallet"
        ],
        "summary": "Fund wallet",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FundWalletInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Funding initiated/completed"
          }
        }
      }
    },
    "/api/wallet/withdraw": {
      "post": {
        "tags": [
          "Wallet"
        ],
        "summary": "Withdraw from wallet",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WithdrawInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Withdrawal processed"
          }
        }
      }
    },
    "/api/wallet/transfer": {
      "post": {
        "tags": [
          "Wallet"
        ],
        "summary": "Transfer funds to another user",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransferInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transfer successful"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SignupInput": {
        "type": "object",
        "required": [
          "first_name",
          "last_name",
          "phone",
          "email",
          "password",
          "bvn"
        ],
        "properties": {
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 6
          },
          "bvn": {
            "type": "string",
            "minLength": 11,
            "maxLength": 11
          }
        }
      },
      "LoginInput": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "ValidateReceiverInput": {
        "type": "object",
        "required": [
          "phone"
        ],
        "properties": {
          "phone": {
            "type": "string",
            "pattern": "^\\d{11}$"
          }
        }
      },
      "FundWalletInput": {
        "type": "object",
        "required": [
          "amount",
          "email",
          "reference"
        ],
        "properties": {
          "amount": {
            "type": "number",
            "minimum": 0
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "reference": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "default": "funding"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "WithdrawInput": {
        "type": "object",
        "required": [
          "amount",
          "reference",
          "counterparty_id",
          "destination_bank_code",
          "counterparty_name"
        ],
        "properties": {
          "amount": {
            "type": "number",
            "minimum": 0,
            "maximum": 10000000
          },
          "reference": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "default": "withdrawal"
          },
          "description": {
            "type": "string"
          },
          "counterparty_id": {
            "type": "string"
          },
          "destination_bank_code": {
            "type": "string"
          },
          "counterparty_name": {
            "type": "string"
          }
        }
      },
      "TransferInput": {
        "type": "object",
        "required": [
          "receiver_user_id",
          "receiver_name",
          "sender_name",
          "amount",
          "reference",
          "category"
        ],
        "properties": {
          "receiver_user_id": {
            "type": "integer",
            "minimum": 0
          },
          "receiver_name": {
            "type": "string"
          },
          "sender_name": {
            "type": "string"
          },
          "amount": {
            "type": "number",
            "minimum": 0,
            "maximum": 10000000
          },
          "reference": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "token"
      }
    }
  }
}