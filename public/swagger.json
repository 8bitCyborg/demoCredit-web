{
  "openapi": "3.0.0",
  "info": {
    "title": "demoCredit API",
    "description": "API documentation for the demoCredit Wallet Service MVP. Focuses on secure wallet operations, concurrency control, and Adjutor integration.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://shalomhope-lendsqr-be-test.onrender.com",
      "description": "Production server"
    }
  ],
  "components": {
    "parameters": {
      "ClientTypeHeader": {
        "name": "x-client-type",
        "in": "header",
        "required": true,
        "description": "Required client identifier (e.g., democredit-webapp)",
        "schema": {
          "type": "string",
          "default": "democredit-webapp"
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "token"
      }
    },
    "schemas": {
      "SignupInput": {
        "type": "object",
        "required": [
          "first_name",
          "last_name",
          "phone",
          "email",
          "password",
          "bvn"
        ],
        "properties": {
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 6
          },
          "bvn": {
            "type": "string",
            "minLength": 11,
            "maxLength": 11
          }
        }
      },
      "LoginInput": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "ValidateReceiverInput": {
        "type": "object",
        "required": [
          "phone"
        ],
        "properties": {
          "phone": {
            "type": "string",
            "pattern": "^\\d{11}$"
          }
        }
      },
      "FundWalletInput": {
        "type": "object",
        "required": [
          "amount",
          "email",
          "reference"
        ],
        "properties": {
          "amount": {
            "type": "number",
            "minimum": 0
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "reference": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "default": "funding"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "WithdrawInput": {
        "type": "object",
        "required": [
          "amount",
          "reference",
          "counterparty_id",
          "destination_bank_code",
          "counterparty_name"
        ],
        "properties": {
          "amount": {
            "type": "number",
            "minimum": 0
          },
          "reference": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "default": "withdrawal"
          },
          "counterparty_id": {
            "type": "string"
          },
          "destination_bank_code": {
            "type": "string"
          },
          "counterparty_name": {
            "type": "string"
          }
        }
      },
      "TransferInput": {
        "type": "object",
        "required": [
          "receiver_user_id",
          "receiver_name",
          "sender_name",
          "amount",
          "reference",
          "category"
        ],
        "properties": {
          "receiver_user_id": {
            "type": "integer"
          },
          "receiver_name": {
            "type": "string"
          },
          "sender_name": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "reference": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/api/auth/signup": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "User signup",
        "parameters": [
          {
            "$ref": "#/components/parameters/ClientTypeHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User created"
          },
          "400": {
            "description": "Validation failed"
          },
          "403": {
            "description": "Forbidden - Blacklisted on Karma"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "User login",
        "parameters": [
          {
            "$ref": "#/components/parameters/ClientTypeHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful"
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "User logout",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ClientTypeHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Logged out successfully"
          }
        }
      }
    },
    "/api/user/validate-receiver": {
      "post": {
        "tags": [
          "User"
        ],
        "summary": "Validate receiver phone number",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ClientTypeHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ValidateReceiverInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Receiver valid"
          }
        }
      }
    },
    "/api/ledger/get-user-ledger": {
      "get": {
        "tags": [
          "Ledger"
        ],
        "summary": "Get user transaction history",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ClientTypeHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Ledger retrieved"
          }
        }
      }
    },
    "/api/wallet": {
      "get": {
        "tags": [
          "Wallet"
        ],
        "summary": "Get wallet balance",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ClientTypeHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Balance data"
          }
        }
      }
    },
    "/api/wallet/fund": {
      "post": {
        "tags": [
          "Wallet"
        ],
        "summary": "Fund wallet",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ClientTypeHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FundWalletInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Funding successful"
          }
        }
      }
    },
    "/api/wallet/withdraw": {
      "post": {
        "tags": [
          "Wallet"
        ],
        "summary": "Withdraw funds",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ClientTypeHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WithdrawInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Withdrawal successful"
          }
        }
      }
    },
    "/api/wallet/transfer": {
      "post": {
        "tags": [
          "Wallet"
        ],
        "summary": "Transfer funds",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ClientTypeHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransferInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transfer successful"
          }
        }
      }
    }
  }
}